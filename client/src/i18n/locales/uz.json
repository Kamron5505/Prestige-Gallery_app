  "testimonials": [
    {
      "name": "Sevara Akramova",
      "text": "Erta tongda buyurtma berdim, tushgacha yetkazib berishdi! Gullar juda yangi va chiroyli edi. Tug'ilgan kunimni unutilmas qilishdi.",
